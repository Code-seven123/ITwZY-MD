    fs.unlink(data, async (err) => {
      conn.sendMessage(id, { text: `fs error ${err}` })
    })*/
//  }
}

handler.cmd = /^(tomp3)$/i
handler.desc = 'convert mp4 to mp3'
handler.category = 'utility'
